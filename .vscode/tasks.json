{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "cargo",
			"args": ["build"],
			"problemMatcher": ["$rustc"],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "cargo build (whole workspace)"
		},
		{
			"label": "run",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--bin", "conflux", "--", "daemon"],
			"problemMatcher": ["$rustc"],
			"group": "none",
			"detail": "cargo run -- daemon (foreground; Ctrl+C to stop)"
		},
		{
			"label": "release: push master → release",
			"type": "shell",
			"command": "git",
			"args": [
				"push",
				"--force",
				"origin",
				"master:release"
			],
			"problemMatcher": [],
			"group": "none",
			"detail": "Force-update the remote 'release' branch to the current master commit (no checkout). Triggers the Release workflow."
		}
	]
}
